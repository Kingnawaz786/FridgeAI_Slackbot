# FridgeChef AI Slack Bot - Environment Configuration Example
# Copy this file to .env and fill in the credentials.

# Slack Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Required for Socket Mode: App-Level Token (starts with xapp-)
SLACK_APP_LEVEL_TOKEN=xapp-your-app-level-token

# Groq API Credentials
GROQ_API_KEY=gsk_your_groq_api_key

# Port to run the Express receiver/health server on (default: 3000)
PORT=3000
